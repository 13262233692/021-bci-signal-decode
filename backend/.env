# Server Config
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
DEBUG=true

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ZeroMQ Config
ZMQ_SUBSCRIBE_HOST=localhost
ZMQ_SUBSCRIBE_PORT=5556
ZMQ_TOPIC=bci

# Signal Config
NUM_CHANNELS=64
SAMPLE_RATE=1000
NOTCH_FREQ=50
BANDPASS_LOW=0.5
BANDPASS_HIGH=300
CHUNK_SIZE=100

# Simulate Mode (set to true when no hardware is available)
SIMULATE_MODE=true
